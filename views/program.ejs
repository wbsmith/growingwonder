<%- include('layout_head', {
  title: program.name,
  ogDescription: program.description,
  ogPath: '/programs/' + (program.slug || program.id),
  ogImage: program.heroImage || null
}) %>

<%- include('_nav') %>

<!-- Hero -->
<% const overlay = program.heroOverlay || 'rgba(44,74,46,0.75)'; %>
<section class="program-hero" <% if (program.heroImage) { %>style="background-image: linear-gradient(<%= overlay %>, <%= overlay %>), url('<%= program.heroImage %>'); background-position: <%= program.heroPosition || 'center center' %>;"<% } %>>
  <div class="program-hero-content">
    <h1><%= program.heroTitle || program.name %></h1>
    <p><%= program.heroSubtitle || program.description %></p>
    <a href="/register/<%= program.slug || program.id %>" class="btn btn-primary">Register Now</a>
  </div>
</section>

<!-- Content -->
<div class="program-page">
  <% if (program.longDescription) { %>
    <div class="program-description">
      <%- program.longDescription %>
    </div>
  <% } %>

  <% const media = program.media || []; %>
  <% const images = media.filter(m => m.type === 'image'); %>
  <% const videos = media.filter(m => m.type === 'video'); %>

  <% if (images.length > 0) { %>
    <div class="program-gallery">
      <% images.forEach(img => { %>
        <div class="gallery-item">
          <img src="<%= img.url %>" alt="<%= img.caption || program.name %>">
          <% if (img.caption) { %>
            <div class="gallery-caption"><%= img.caption %></div>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>

  <% if (videos.length > 0) { %>
    <div class="program-videos">
      <% videos.forEach(vid => { %>
        <div class="video-item">
          <video controls preload="metadata">
            <source src="<%= vid.url %>">
          </video>
          <% if (vid.caption) { %>
            <div class="gallery-caption"><%= vid.caption %></div>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>

  <% if (!program.longDescription && media.length === 0) { %>
    <div style="text-align: center; color: var(--text-light); padding: 40px;">
      <p>More details coming soon.</p>
    </div>
  <% } %>

  <div class="program-cta">
    <a href="/register/<%= program.slug || program.id %>" class="btn btn-green">Register for <%= program.name %></a>
    <a href="/#programs" class="btn btn-outline" style="margin-left: 12px;">All Programs</a>
  </div>
</div>

<%- include('_footer') %>

<%- include('layout_foot') %>
