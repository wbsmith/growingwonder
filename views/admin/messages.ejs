<%- include('../layout_head', { title: 'Messages' }) %>
<link rel="stylesheet" href="/css/admin.css">

<div class="admin-layout">
  <%- include('_sidebar', { active: 'messages', tab: tab, unreadInbox: typeof unreadInbox !== 'undefined' ? unreadInbox : 0 }) %>
  <main class="admin-main">
    <h1><%= tab === 'bulk' ? 'Bulk Send' : tab === 'inquiries' ? 'Inquiries' : 'Inbox' %></h1>

    <% if (tab === 'confirmations') { %>
      <!-- INBOX TAB (mirrors registration@ + info@; threaded) -->
      <%
        const filterOpts = [
          { key: 'all', label: 'All' },
          { key: 'registration', label: 'Registration' },
          { key: 'info', label: 'Info' },
          { key: 'unread', label: 'Unread' },
          { key: 'confirmations', label: 'Confirmations' },
        ];
        const activeFilter = typeof filter !== 'undefined' ? filter : 'all';
      %>
      <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; margin-bottom:16px;">
        <div style="display:flex; gap:6px; flex-wrap:wrap;">
          <% filterOpts.forEach(f => { %>
            <a href="/admin/messages?tab=confirmations&filter=<%= f.key %>"
               class="btn btn-sm <%= activeFilter === f.key ? 'btn-green' : 'btn-outline' %>"><%= f.label %></a>
          <% }) %>
        </div>
        <div style="display:flex; align-items:center; gap:10px;">
          <span id="refreshStatus" style="font-size:0.8rem; color:var(--text-light);"></span>
          <% if (mailEnabled) { %>
            <button type="button" class="btn btn-outline btn-sm" id="refreshInboxBtn" onclick="refreshInbox(true)">&#x21bb; Refresh</button>
          <% } else { %>
            <span style="font-size:0.8rem; color:var(--text-light);" title="Set MAIL_* env vars to enable inbound sync">Inbound not configured</span>
          <% } %>
        </div>
      </div>

      <% if (threads.length === 0) { %>
        <p style="color: var(--text-light);">No messages<%= activeFilter !== 'all' ? ' for this filter' : '' %>.</p>
      <% } else { %>
        <table class="data-table">
          <thead>
            <tr>
              <th></th>
              <th>From / To</th>
              <th>Subject</th>
              <th>Messages</th>
              <th>Latest</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% threads.forEach(t => { %>
              <%
                const href = t.registrationId
                  ? '/admin/messages/thread/' + t.registrationId
                  : '/admin/messages/thread/addr/' + encodeURIComponent(t.addr);
              %>
              <tr style="<%= t.unreadCount > 0 ? 'font-weight:600; background:#f4f8f3;' : '' %>">
                <td style="white-space:nowrap;">
                  <% if (t.unreadCount > 0) { %><span title="<%= t.unreadCount %> unread" style="display:inline-block; width:9px; height:9px; border-radius:50%; background:var(--green-mid); vertical-align:middle;"></span><% } %>
                  <% if (t.latestStatus === 'draft') { %><span class="badge badge-draft">draft</span><% } %>
                  <% if (t.latestStatus === 'failed') { %><span class="badge badge-failed">failed</span><% } %>
                </td>
                <td>
                  <div><%= t.toAddr %></div>
                  <% if (t.parentName) { %><div style="font-size:0.78rem; color:var(--text-light); font-weight:normal;"><%= t.parentName %><%= t.childName ? ' · ' + t.childName : '' %></div><% } %>
                </td>
                <td>
                  <div><%= t.subject %><% if (t.isRegistration) { %> <span style="display:inline-block; font-size:0.7rem; font-weight:700; padding:1px 6px; border-radius:8px; color:var(--green-dark); border:1px solid var(--green-mid); vertical-align:middle;">Confirmation</span><% } %></div>
                  <% if (t.latestSnippet) { %><div style="font-size:0.78rem; color:var(--text-light); font-weight:normal; max-width:340px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"><%= t.latestDirection === 'in' ? '↩ ' : '' %><%= t.latestSnippet %></div><% } %>
                </td>
                <td style="text-align: center;">
                  <% if (t.messageCount > 1) { %>
                    <span style="background: var(--green-dark); color: white; border-radius: 10px; padding: 1px 7px; font-size: 0.75rem; font-weight: 600;"><%= t.messageCount %></span>
                  <% } else { %>
                    1
                  <% } %>
                </td>
                <td style="font-size: 0.8rem;"><%= t.latestDate %></td>
                <td style="white-space:nowrap;">
                  <a href="<%= href %>" class="btn btn-outline btn-sm">
                    <%= t.latestStatus === 'draft' ? 'Open' : t.messageCount > 1 ? 'View Thread' : 'View' %>
                  </a>
                  <form method="POST" action="/admin/messages/delete" style="display:inline; margin-left: 4px;">
                    <input type="hidden" name="type" value="email">
                    <input type="hidden" name="item_id" value="<%= t.messages.map(m => m.id).join(',') %>">
                    <button type="submit" style="background:none;border:none;color:var(--red);cursor:pointer;font-size:1rem;padding:2px 4px;vertical-align:middle;" title="Delete"
                      onclick="return confirm('<%= t.messageCount > 1 ? 'Delete all ' + t.messageCount + ' messages in this thread?' : 'Delete this message?' %>')">&#x1F5D1;</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>

      <% if (mailEnabled) { %>
      <script>
        // Pull new inbound mail. Auto-runs once on load (silent); the Refresh
        // button runs it explicitly. Reloads to surface anything new.
        async function refreshInbox(manual) {
          const status = document.getElementById('refreshStatus');
          const btn = document.getElementById('refreshInboxBtn');
          if (btn) btn.disabled = true;
          if (status) status.textContent = manual ? 'Checking mail…' : '';
          try {
            const res = await fetch('/admin/messages/refresh', { method: 'POST' });
            const data = await res.json();
            if (data.ok && data.total > 0) { window.location.reload(); return; }
            if (status) status.textContent = manual ? (data.ok ? 'No new messages.' : ('Error: ' + (data.error || 'sync failed'))) : '';
          } catch (e) {
            if (status) status.textContent = manual ? 'Refresh failed.' : '';
          } finally {
            if (btn) btn.disabled = false;
          }
        }
        // Silent auto-check shortly after load so replies appear without a click.
        window.addEventListener('load', function () { setTimeout(function () { refreshInbox(false); }, 400); });
      </script>
      <% } %>

    <% } else if (tab === 'bulk') { %>
      <!-- BULK SEND TAB -->
      <div style="background: var(--white); border-radius: var(--radius); padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); margin-bottom: 24px;">
        <h3 style="margin-bottom: 16px; color: var(--green-dark); font-size: 1rem;">Select Recipients</h3>
        <div style="display: flex; gap: 16px; flex-wrap: wrap; align-items: flex-end;">
          <div class="form-group" style="margin-bottom: 0;">
            <label>Scope</label>
            <select id="scope" onchange="updateScopeUI()">
              <option value="manual">Manual only</option>
              <option value="all">All enrolled parents</option>
              <option value="program">All in a program</option>
              <option value="week">Enrolled in a week</option>
              <option value="day">Enrolled on a day</option>
            </select>
          </div>
          <div class="form-group" style="margin-bottom: 0; display: none;" id="programGroup">
            <label>Program</label>
            <select id="bulkProgramSelect" onchange="updateDateOptions()">
              <option value="">Choose...</option>
              <% programs.forEach(p => { %>
                <option value="<%= p.id %>"><%= p.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group" style="margin-bottom: 0; display: none;" id="weekGroup">
            <label>Week</label>
            <select id="weekSelect"></select>
          </div>
          <div class="form-group" style="margin-bottom: 0; display: none;" id="dayGroup">
            <label>Date</label>
            <select id="daySelect"></select>
          </div>
          <button type="button" class="btn btn-outline btn-sm" id="loadRecipientsBtn" onclick="fetchRecipients()">Load Recipients</button>
        </div>
        <div id="recipientInfo" style="margin-top: 16px; display: none;">
          <strong id="recipientCount">0</strong> recipient(s):
          <div id="recipientList" style="font-size: 0.8rem; color: var(--text-light); margin-top: 4px; max-height: 100px; overflow-y: auto;"></div>
        </div>
      </div>
      <form method="POST" action="/admin/messages/bulk/send" id="bulkSendForm">
        <input type="hidden" name="recipients" id="recipientHidden">
        <input type="hidden" name="body" id="bulkBodyHidden">
        <input type="hidden" name="body_format" value="html">
        <input type="hidden" name="attachment_keys" id="bulkAttachKeys" value="">

        <!-- Manual recipients -->
        <div class="form-group">
          <label id="manualRecipientsLabel">Recipients <span style="font-weight:normal; color:var(--text-light);">(comma-separated emails)</span></label>
          <input type="text" id="manualRecipients" placeholder="parent@example.com, another@example.com"
            style="padding: 10px 14px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;">
        </div>

        <div class="form-group">
          <label>Subject</label>
          <input type="text" name="subject" required style="padding: 10px 14px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;">
        </div>

        <!-- Rich text editor -->
        <div class="form-group">
          <label>Message</label>
          <link href="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css" rel="stylesheet">
          <div id="bulkEditor" style="min-height: 200px; background: var(--white);"></div>
        </div>

        <!-- Attachments -->
        <div style="margin-bottom: 16px; padding: 16px; background: var(--white); border-radius: var(--radius); border: 1px solid #ddd;">
          <label style="font-weight: 700; font-size: 0.9rem; display: block; margin-bottom: 8px;">Attachments</label>
          <div id="bulkAttachList"></div>
          <div style="display: flex; gap: 8px; align-items: center;">
            <input type="file" id="bulkAttachFile" style="font-size: 0.85rem;">
            <button type="button" class="btn btn-outline btn-sm" onclick="addBulkAttachment()">Add</button>
          </div>
          <div id="bulkAttachStatus" style="font-size: 0.85rem; color: var(--text-light); margin-top: 4px;"></div>
        </div>

        <button type="submit" class="btn btn-green" id="sendBtn">
          Send Email
        </button>
      </form>
      <script src="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js"></script>
      <script src="/js/admin-quill.js"></script>
      <script>
      const programWeeks = <%- JSON.stringify(programWeeks) %>;

      const bulkQuill = createAdminQuill('#bulkEditor', {
        placeholder: 'Type your message...',
      });

      // Merge manual + loaded recipients and set body on submit
      document.getElementById('bulkSendForm').addEventListener('submit', function() {
        document.getElementById('bulkBodyHidden').value = bulkQuill.getCleanHtml();

        // Merge manual recipients
        const loaded = (document.getElementById('recipientHidden').value || '').split(',').filter(Boolean);
        const manual = (document.getElementById('manualRecipients').value || '').split(',').map(e => e.trim()).filter(Boolean);
        const all = [...new Set([...loaded, ...manual])];
        document.getElementById('recipientHidden').value = all.join(',');

        // Update count for confirm
        if (all.length === 0) {
          alert('No recipients specified.');
          return false;
        }
      });
      function updateScopeUI() {
        const scope = document.getElementById('scope').value;
        const isManual = scope === 'manual';
        document.getElementById('programGroup').style.display = (scope === 'all' || isManual) ? 'none' : '';
        document.getElementById('weekGroup').style.display = (scope === 'week') ? '' : 'none';
        document.getElementById('dayGroup').style.display = (scope === 'day') ? '' : 'none';
        document.getElementById('loadRecipientsBtn').style.display = isManual ? 'none' : '';
        document.getElementById('recipientInfo').style.display = 'none';
        document.getElementById('recipientHidden').value = '';
        document.getElementById('sendBtn').disabled = !isManual;
        document.getElementById('manualRecipientsLabel').innerHTML = isManual
          ? 'Recipients <span style="font-weight:normal; color:var(--text-light);">(comma-separated emails)</span>'
          : 'Additional Recipients <span style="font-weight:normal; color:var(--text-light);">(comma-separated emails)</span>';
      }
      function updateDateOptions() {
        const pid = document.getElementById('bulkProgramSelect').value;
        if (!pid || !programWeeks[pid]) return;
        const data = programWeeks[pid];
        const weekSel = document.getElementById('weekSelect');
        weekSel.innerHTML = '';
        data.weeks.forEach(w => { const o = document.createElement('option'); o.value = w.monday; o.textContent = w.monday + ' to ' + w.friday; weekSel.appendChild(o); });
        const daySel = document.getElementById('daySelect');
        daySel.innerHTML = '';
        data.dates.forEach(d => { const o = document.createElement('option'); o.value = d; const dt = new Date(d+'T00:00:00'); o.textContent = dt.toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'})+' ('+d+')'; daySel.appendChild(o); });
      }
      async function fetchRecipients() {
        const scope = document.getElementById('scope').value;
        const programId = document.getElementById('bulkProgramSelect').value;
        const body = { scope };
        if (scope !== 'all') body.programId = programId;
        if (scope === 'week') body.weekStart = document.getElementById('weekSelect').value;
        if (scope === 'day') body.date = document.getElementById('daySelect').value;
        const res = await fetch('/admin/messages/bulk/recipients', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
        const data = await res.json();
        document.getElementById('recipientCount').textContent = data.count;
        document.getElementById('recipientList').textContent = data.emails.join(', ');
        document.getElementById('recipientHidden').value = data.emails.join(',');
        document.getElementById('recipientInfo').style.display = 'block';
        document.getElementById('sendBtn').disabled = data.count === 0;
      }

      // Bulk attachments
      const bulkAttachments = []; // [{filename, key, contentType}]
      async function addBulkAttachment() {
        const file = document.getElementById('bulkAttachFile').files[0];
        const status = document.getElementById('bulkAttachStatus');
        if (!file) { status.textContent = 'Select a file first.'; return; }
        status.textContent = 'Uploading...';
        try {
          const res = await fetch('/admin/messages/bulk/upload-url', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ filename: file.name, contentType: file.type }),
          });
          const presigned = await res.json();
          await fetch(presigned.uploadUrl, { method: 'PUT', headers: { 'Content-Type': file.type }, body: file });
          bulkAttachments.push({ filename: file.name, key: presigned.key, contentType: file.type });
          renderBulkAttachments();
          document.getElementById('bulkAttachFile').value = '';
          status.textContent = '';
        } catch (err) {
          status.textContent = 'Upload failed: ' + err.message;
        }
      }
      function renderBulkAttachments() {
        const list = document.getElementById('bulkAttachList');
        list.innerHTML = bulkAttachments.map((a, i) =>
          '<div style="display:flex;align-items:center;gap:8px;padding:4px 0;font-size:0.85rem;">' +
          '<span>' + a.filename + '</span>' +
          '<a href="#" onclick="removeBulkAttachment(' + i + '); return false;" style="color:var(--red);font-size:0.8rem;">Remove</a>' +
          '</div>'
        ).join('');
        document.getElementById('bulkAttachKeys').value = JSON.stringify(bulkAttachments);
      }
      function removeBulkAttachment(idx) {
        bulkAttachments.splice(idx, 1);
        renderBulkAttachments();
      }
      </script>

    <% } else if (tab === 'inquiries') { %>
      <!-- INQUIRIES TAB -->
      <% if (inquiries.length === 0) { %>
        <p style="color: var(--text-light);">No inquiries yet.</p>
      <% } else { %>
        <table class="data-table">
          <thead>
            <tr>
              <th>Status</th>
              <th>Subject</th>
              <th>From</th>
              <th>Contact</th>
              <th>Message</th>
              <th>Received</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% inquiries.forEach(i => { %>
              <tr>
                <td><span class="badge badge-<%= i.status === 'new' ? 'draft' : 'sent' %>"><%= i.status %></span></td>
                <td><%= i.subject %></td>
                <td><%= i.name || '—' %></td>
                <td style="font-size: 0.8rem;">
                  <% if (i.email) { %><div><%= i.email %></div><% } %>
                  <% if (i.phone) { %><div><%= i.phone %></div><% } %>
                </td>
                <td style="font-size: 0.85rem; max-width: 250px;"><%= i.message %></td>
                <td style="font-size: 0.8rem;"><%= i.createdAt %></td>
                <td>
                  <a href="/admin/messages/inquiries/<%= i.id %>" class="btn btn-outline btn-sm"><%= i.status === 'new' ? 'Reply' : 'View' %></a>
                  <form method="POST" action="/admin/messages/delete" style="display:inline; margin-left: 4px;">
                    <input type="hidden" name="type" value="inquiry">
                    <input type="hidden" name="item_id" value="<%= i.id %>">
                    <button type="submit" style="background:none;border:none;color:var(--red);cursor:pointer;font-size:0.9rem;padding:2px 4px;" title="Delete"
                      onclick="return confirm('Delete this inquiry?')">&times;</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    <% } %>
  </main>
</div>

<%- include('../layout_foot') %>
