<%- include('../layout_head', { title: 'Admin Dashboard' }) %>
<link rel="stylesheet" href="/css/admin.css">

<div class="admin-layout">
  <%- include('_sidebar', { active: 'dashboard' }) %>
  <main class="admin-main">
    <h1>Dashboard</h1>

    <div class="stats-grid">
      <% stats.forEach(s => { %>
        <a class="stat-card" href="/admin/enrollments?tab=registrations&program=<%= s.id %>">
          <div class="number"><%= s.total_registrations %></div>
          <div class="label"><%= s.name %> registrations</div>
        </a>
      <% }) %>
      <a class="stat-card" href="/admin/messages?tab=confirmations">
        <div class="number"><%= pendingEmails %></div>
        <div class="label">Emails pending review</div>
      </a>
      <a class="stat-card" href="/admin/messages?tab=inquiries">
        <div class="number"><%= newInquiries %></div>
        <div class="label">New inquiries</div>
      </a>
    </div>
  </main>
</div>

<%- include('../layout_foot') %>
