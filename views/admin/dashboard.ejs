<%- include('../layout_head', { title: 'Admin Dashboard' }) %>
<link rel="stylesheet" href="/css/admin.css">

<div class="admin-layout">
  <%- include('_sidebar', { active: 'dashboard' }) %>
  <main class="admin-main">
    <h1>Dashboard</h1>

    <div class="stats-grid">
      <% stats.forEach(s => { %>
        <div class="stat-card">
          <div class="number"><%= s.total_registrations %></div>
          <div class="label"><%= s.name %> registrations</div>
        </div>
      <% }) %>
      <div class="stat-card">
        <div class="number"><%= pendingEmails %></div>
        <div class="label">Emails pending review</div>
      </div>
      <div class="stat-card">
        <div class="number"><%= newInquiries %></div>
        <div class="label">New inquiries</div>
      </div>
    </div>
  </main>
</div>

<%- include('../layout_foot') %>
