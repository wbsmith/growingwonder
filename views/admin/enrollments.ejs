<%- include('../layout_head', { title: 'Enrollments' }) %>
<link rel="stylesheet" href="/css/admin.css">

<div class="admin-layout">
  <%- include('_sidebar', { active: 'enrollments', tab: tab }) %>
  <main class="admin-main">
    <h1><%= tab === 'payments' ? 'Payments' : tab === 'summary' ? 'Registration Summary' : tab === 'rosters' ? 'Rosters' : tab === 'import' ? 'Import Contacts' : 'Registrations' %></h1>

    <!-- Program filter (shared across tabs) -->
    <form method="GET" action="/admin/enrollments" class="inline-form" style="margin-bottom: 24px;">
      <input type="hidden" name="tab" value="<%= tab %>">
      <div class="form-group" style="margin-bottom: 0;">
        <select name="program" onchange="this.form.submit()">
          <option value="">All programs</option>
          <% programs.forEach(p => { %>
            <option value="<%= p.id %>" <%= selectedProgramId === p.id ? 'selected' : '' %>><%= p.name %></option>
          <% }) %>
        </select>
      </div>
    </form>

    <% if (tab === 'registrations') { %>
      <!-- REGISTRATIONS TAB -->
      <% if (enrollments.length === 0) { %>
        <p style="color: var(--text-light);">No registrations yet.</p>
      <% } else { %>
        <form method="POST" action="/admin/enrollments/merge" id="mergeForm">
          <input type="hidden" name="merge_mode" id="mergeMode" value="selected">
          <input type="hidden" name="merge_field" id="mergeField" value="">
          <div style="margin-bottom: 12px; display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
            <button type="submit" class="btn btn-outline btn-sm" id="mergeBtn" disabled
              onclick="return confirm('Merge selected registrations? Dates, children, and confirmation emails will be combined.')">
              Merge Selected
            </button>
            <button type="button" class="btn btn-outline btn-sm" onclick="openAutoMergeModal()">
              Auto-Merge Duplicates
            </button>
            <span id="mergeCount" style="font-size: 0.8rem; color: var(--text-light);"></span>
          </div>
        <table class="data-table">
          <thead>
            <tr>
              <th style="width: 30px;"><input type="checkbox" id="selectAll" onclick="toggleAll(this)"></th>
              <th>Program</th>
              <th>Children</th>
              <th>Parent</th>
              <th>Email</th>
              <th>Phone</th>
              <th>Dates</th>
              <th>Registered</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% enrollments.forEach(e => { %>
              <tr>
                <td><input type="checkbox" name="merge_ids" value="<%= e.id %>" class="merge-check" onchange="updateMergeBtn()"></td>
                <td><%= e.programName %></td>
                <td>
                  <% (e.children || []).forEach(c => { %>
                    <div style="font-size: 0.85rem;"><strong><%= c.name %></strong> (<%= c.dob %>)</div>
                  <% }) %>
                  <% const responses = (e.customResponses || []).filter(r => r && r.value); %>
                  <% if (responses.length > 0) { %>
                    <div style="margin-top: 6px; padding: 6px 8px; background: var(--sand); border-radius: 4px; font-size: 0.75rem; line-height: 1.4;">
                      <% responses.forEach(r => { %>
                        <div><strong><%= r.label %>:</strong> <%= r.value %></div>
                      <% }) %>
                    </div>
                  <% } %>
                </td>
                <td><%= e.parentName %></td>
                <td><%= e.parentEmail %></td>
                <td><%= e.parentPhone %></td>
                <td style="font-size: 0.8rem;">
                  <%
                    const dates = (e.selectedDates || []).sort();
                    let lastYM = '';
                    dates.forEach(d => {
                      const [y, m, day] = d.split('-');
                      const ym = y + '-' + m;
                      const monthName = new Date(d + 'T00:00:00').toLocaleDateString('en-US', { month: 'short' });
                      if (ym !== lastYM) {
                        if (lastYM) { %><br><% }
                        %><strong><%= monthName %> <%= y %>:</strong> <%
                        lastYM = ym;
                      }
                      %><span style="white-space: nowrap;"><%= parseInt(day) %><form method="POST" action="/admin/enrollments/remove-date" style="display:inline;"><input type="hidden" name="registration_id" value="<%= e.id %>"><input type="hidden" name="date" value="<%= d %>"><button type="submit" style="background:none;border:none;color:var(--red);cursor:pointer;font-size:0.7rem;padding:0 2px;" title="Remove this date" onclick="return confirm('Remove <%= d %> from this registration?')">&times;</button></form></span> <%
                    });
                  %>
                </td>
                <td style="font-size: 0.8rem;"><%= e.createdAt %></td>
                <td>
                  <form method="POST" action="/admin/enrollments/delete" style="display:inline;">
                    <input type="hidden" name="registration_id" value="<%= e.id %>">
                    <button type="submit" class="btn btn-danger btn-sm"
                      onclick="return confirm('Delete entire registration for <%= e.parentName %>?')">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </form>

        <!-- Auto-merge modal -->
        <div id="autoMergeModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); z-index: 100; align-items: center; justify-content: center;">
          <div style="background: var(--white); border-radius: 12px; padding: 32px; max-width: 400px; width: 90%; box-shadow: 0 8px 30px rgba(0,0,0,0.2);">
            <h3 style="color: var(--green-dark); margin-bottom: 16px;">Auto-Merge Duplicates</h3>
            <p style="font-size: 0.85rem; color: var(--text-light); margin-bottom: 16px;">
              Automatically merge registrations that share the same contact info. Dates, children, and confirmation emails will be combined.
            </p>
            <div class="form-group">
              <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-weight: 400;">
                <input type="radio" name="auto_merge_field" value="email" checked> Match by email address
              </label>
            </div>
            <div class="form-group">
              <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-weight: 400;">
                <input type="radio" name="auto_merge_field" value="phone"> Match by phone number
              </label>
            </div>
            <div class="form-group">
              <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-weight: 400;">
                <input type="radio" name="auto_merge_field" value="both"> Match by email OR phone
              </label>
            </div>
            <div style="display: flex; gap: 12px; margin-top: 16px;">
              <button type="button" class="btn btn-green btn-sm" onclick="submitAutoMerge()">Merge</button>
              <button type="button" class="btn btn-outline btn-sm" onclick="closeAutoMergeModal()">Cancel</button>
            </div>
          </div>
        </div>

        <script>
        function toggleAll(el) {
          document.querySelectorAll('.merge-check').forEach(c => { c.checked = el.checked; });
          updateMergeBtn();
        }
        function updateMergeBtn() {
          const checked = document.querySelectorAll('.merge-check:checked');
          const btn = document.getElementById('mergeBtn');
          const count = document.getElementById('mergeCount');
          btn.disabled = checked.length < 2;
          count.textContent = checked.length > 0 ? checked.length + ' selected' : '';
        }
        function openAutoMergeModal() {
          document.getElementById('autoMergeModal').style.display = 'flex';
        }
        function closeAutoMergeModal() {
          document.getElementById('autoMergeModal').style.display = 'none';
        }
        document.getElementById('autoMergeModal').addEventListener('click', function(e) {
          if (e.target === this) closeAutoMergeModal();
        });
        function submitAutoMerge() {
          const field = document.querySelector('input[name="auto_merge_field"]:checked').value;
          if (!confirm('Auto-merge all duplicate registrations matching by ' + field + '?')) return;
          document.getElementById('mergeMode').value = 'auto';
          document.getElementById('mergeField').value = field;
          document.getElementById('mergeForm').submit();
        }
        </script>
      <% } %>

    <% } else if (tab === 'payments') { %>
      <!-- PAYMENTS TAB -->
      <% if (enrollments.length === 0) { %>
        <p style="color: var(--text-light);">No registrations.</p>
      <% } else { %>
        <div style="text-align: right; margin-bottom: 12px;">
          <a href="/admin/enrollments/csv<%= selectedProgramId ? '?program=' + selectedProgramId : '' %>"
             class="btn btn-outline btn-sm">Export CSV</a>
        </div>
        <table class="data-table" id="statusTable">
          <thead>
            <tr>
              <th>Parent</th>
              <th>Contact</th>
              <th>Children</th>
              <th>Program</th>
              <th>Dates</th>
              <th>Confirmed</th>
              <th style="cursor: pointer;" onclick="sortByPayment()">Payment <span id="sortArrow">&#9650;</span></th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% enrollments.forEach(r => { %>
              <%
                const unpaid = (r.paymentAmount == null || r.paymentAmount === 0);
                const rowClass = unpaid ? 'unpaid-row' : '';
              %>
              <tr class="<%= rowClass %>" data-amount="<%= r.paymentAmount != null ? r.paymentAmount : -1 %>">
                <td><%= r.parentName %></td>
                <td style="font-size: 0.8rem;">
                  <div><%= r.parentEmail %></div>
                  <div><%= r.parentPhone %></div>
                </td>
                <td>
                  <% (r.children || []).forEach(c => { %>
                    <div style="font-size: 0.85rem;"><%= c.name %> (<%= c.dob %>)</div>
                  <% }) %>
                </td>
                <td><%= r.programName %></td>
                <td style="font-size: 0.8rem;">
                  <%
                    const pdates = (r.selectedDates || []).sort();
                    let plastYM = '';
                    pdates.forEach(d => {
                      const [y, m, day] = d.split('-');
                      const ym = y + '-' + m;
                      const monthName = new Date(d + 'T00:00:00').toLocaleDateString('en-US', { month: 'short' });
                      if (ym !== plastYM) {
                        if (plastYM) { %><br><% }
                        %><strong><%= monthName %> <%= y %>:</strong> <%
                        plastYM = ym;
                      }
                      %><%= parseInt(day) %> <%
                    });
                  %>
                </td>
                <td style="font-size: 0.8rem;"><%= r.confirmationDate || '—' %></td>
                <td style="font-size: 0.8rem;">
                  <% if (r.paymentAmount != null || r.paymentDate) { %>
                    <% if (r.paymentAmount != null) { %><div><strong>$<%= r.paymentAmount.toFixed(2) %></strong></div><% } %>
                    <% if (r.paymentDate) { %><div><%= r.paymentDate %></div><% } %>
                    <% if (r.paymentNotes) { %><div style="font-size: 0.75rem; color: var(--text-light);"><%= r.paymentNotes %></div><% } %>
                  <% } else { %>
                    <span style="color: var(--text-light);">—</span>
                  <% } %>
                </td>
                <td>
                  <button type="button" class="btn btn-outline btn-sm" onclick="openEdit('<%= r.id %>')">Edit</button>
                  <form method="POST" action="/admin/enrollments/delete" style="display:inline; margin-left: 4px;">
                    <input type="hidden" name="registration_id" value="<%= r.id %>">
                    <button type="submit" class="btn btn-danger btn-sm"
                      onclick="return confirm('Delete registration for <%= r.parentName %>?')">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>

      <!-- Payment edit modal -->
      <div id="editModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); z-index: 100; align-items: center; justify-content: center;">
        <div style="background: var(--white); border-radius: 12px; padding: 32px; max-width: 440px; width: 90%; box-shadow: 0 8px 30px rgba(0,0,0,0.2);">
          <h3 style="color: var(--green-dark); margin-bottom: 20px;">Update Payment</h3>
          <form method="POST" action="/admin/enrollments/payment">
            <input type="hidden" name="registration_id" id="editRegId">
            <div class="form-group">
              <label>Payment Date</label>
              <input type="date" name="payment_date" id="editPayDate">
            </div>
            <div class="form-group">
              <label>Amount ($)</label>
              <input type="number" name="payment_amount" id="editPayAmount" step="0.01" min="0">
            </div>
            <div class="form-group">
              <label>Notes</label>
              <textarea name="payment_notes" id="editPayNotes" rows="2" style="width:100%; padding:8px; border:1px solid #ccc; border-radius:var(--radius); font-family:inherit;"></textarea>
            </div>
            <div style="display: flex; gap: 12px;">
              <button type="submit" class="btn btn-green btn-sm">Save</button>
              <button type="button" class="btn btn-outline btn-sm" onclick="closeEdit()">Cancel</button>
            </div>
          </form>
        </div>
      </div>

      <style>.unpaid-row td { background: #fdf0ef; } .unpaid-row:hover td { background: #fbe3e0; }</style>
      <script>
      const paymentData = <%- JSON.stringify(enrollments.reduce((acc, r) => { acc[r.id] = { date: r.paymentDate || '', amount: r.paymentAmount != null ? String(r.paymentAmount) : '', notes: r.paymentNotes || '' }; return acc; }, {})) %>;
      function openEdit(id) {
        const d = paymentData[id] || {};
        document.getElementById('editRegId').value = id;
        document.getElementById('editPayDate').value = d.date;
        document.getElementById('editPayAmount').value = d.amount;
        document.getElementById('editPayNotes').value = d.notes;
        document.getElementById('editModal').style.display = 'flex';
      }
      function closeEdit() { document.getElementById('editModal').style.display = 'none'; }
      document.getElementById('editModal').addEventListener('click', function(e) { if (e.target === this) closeEdit(); });
      let sortAsc = true;
      function sortByPayment() {
        const tbody = document.querySelector('#statusTable tbody');
        const rows = Array.from(tbody.querySelectorAll('tr'));
        rows.sort((a, b) => { return sortAsc ? parseFloat(a.dataset.amount) - parseFloat(b.dataset.amount) : parseFloat(b.dataset.amount) - parseFloat(a.dataset.amount); });
        sortAsc = !sortAsc;
        document.getElementById('sortArrow').innerHTML = sortAsc ? '&#9650;' : '&#9660;';
        rows.forEach(r => tbody.appendChild(r));
      }
      </script>

    <% } else if (tab === 'summary') { %>
      <!-- SUMMARY TAB -->
      <% if (!selectedProgramId) { %>
        <p style="color: var(--text-light);">Select a program above to view the summary.</p>
      <% } else if (!summaryWeeks || summaryWeeks.length === 0) { %>
        <p style="color: var(--text-light);">No dates configured for this program.</p>
      <% } else { %>
        <%
          const anyWeekend = summaryWeeks.some(w => w.hasWeekend);
          const dayHeaders = anyWeekend
            ? ['Sun','Mon','Tue','Wed','Thu','Fri','Sat']
            : ['Mon','Tue','Wed','Thu','Fri'];
          const dayDows = anyWeekend ? [0,1,2,3,4,5,6] : [1,2,3,4,5];

          function heatColor(count, capacity) {
            if (!capacity || count === 0) return '';
            const pct = Math.min(count / capacity, 1);
            // Green gradient: light → dark
            const r = Math.round(232 - pct * 100);
            const g = Math.round(245 - pct * 40);
            const b = Math.round(233 - pct * 110);
            return 'background:rgb(' + r + ',' + g + ',' + b + ');';
          }
        %>
        <div style="display: inline-block;">
        <table style="border-collapse: collapse; font-size: 0.8rem;">
          <thead>
            <tr>
              <th style="padding: 6px 10px; border: 1px solid #bbb; background: var(--green-dark); color: white; font-size: 0.75rem;">Week</th>
              <% dayHeaders.forEach(h => { %>
                <th style="padding: 6px 8px; border: 1px solid #bbb; background: var(--green-dark); color: white; text-align: center; font-size: 0.75rem; min-width: 36px;"><%= h %></th>
              <% }) %>
              <th style="padding: 6px 8px; border: 1px solid #bbb; background: var(--sand); text-align: center; font-size: 0.7rem;">Fam</th>
              <th style="padding: 6px 8px; border: 1px solid #bbb; background: var(--sand); text-align: center; font-size: 0.7rem;">Tot</th>
            </tr>
          </thead>
          <tbody>
            <% summaryWeeks.forEach(week => { %>
              <tr>
                <td style="padding: 5px 8px; border: 1px solid #ccc; white-space: nowrap; font-weight: 600; font-size: 0.75rem; background: #fafaf7;">
                  <%
                    const wm = new Date(week.monday + 'T00:00:00');
                    const endDate = anyWeekend ? new Date(week.sunday + 'T00:00:00') : new Date(week.friday + 'T00:00:00');
                  %>
                  <%= wm.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>&ndash;<%= endDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
                </td>
                <% dayDows.forEach(dow => {
                  const di = week.days.find(d => d.dow === dow);
                  const full = di && di.available && di.capacity && di.count >= di.capacity;
                %>
                  <td style="padding: 5px 8px; border: 1px solid #ccc; text-align: center; <%= di && di.available ? heatColor(di.count, di.capacity) : 'background: #f5f4f0; color: #ccc;' %>">
                    <% if (di && di.available) { %>
                      <span style="<%= full ? 'color: var(--red); font-weight: 700;' : 'font-weight: 600;' %>"><%= di.count %></span>
                    <% } else { %>
                      &mdash;
                    <% } %>
                  </td>
                <% }) %>
                <td style="padding: 5px 8px; border: 1px solid #ccc; text-align: center; font-weight: 700; background: #fafaf7;"><%= week.distinctFamilies %></td>
                <td style="padding: 5px 8px; border: 1px solid #ccc; text-align: center; font-weight: 700; background: #fafaf7;"><%= week.totalPersons %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      <% } %>

    <% } else if (tab === 'rosters') { %>
      <!-- ROSTERS TAB -->
      <% if (!selectedProgramId) { %>
        <p style="color: var(--text-light);">Select a program above to generate rosters.</p>
      <% } else if (weeks.length === 0) { %>
        <p style="color: var(--text-light);">No dates configured for this program.</p>
      <% } else { %>
        <div style="display: flex; gap: 12px; align-items: flex-end; flex-wrap: wrap;">
          <div class="form-group" style="margin-bottom: 0;">
            <label>Week</label>
            <select id="rosterWeek">
              <% weeks.forEach(w => { %>
                <option value="<%= w.monday %>"><%= w.monday %> to <%= w.friday %></option>
              <% }) %>
            </select>
          </div>
          <a id="rosterLink" href="#" class="btn btn-green btn-sm" target="_blank"
             onclick="this.href='/admin/roster?program=<%= selectedProgramId %>&week='+document.getElementById('rosterWeek').value">
            Print Roster
          </a>
        </div>
      <% } %>

    <% } else if (tab === 'import') { %>
      <!-- IMPORT TAB -->
      <div style="background: var(--white); border-radius: var(--radius); padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); margin-bottom: 24px;">
        <h3 style="margin-bottom: 8px; color: var(--green-dark); font-size: 1rem;">Upload CSV</h3>
        <p style="font-size: 0.85rem; color: var(--text-light); margin-bottom: 16px;">
          CSV columns: <code>parent_name, email, phone, child_name, child_dob, allergies, notes</code><br>
          Multiple children per parent: use one row per child with the same parent name/email.
        </p>
        <form method="POST" action="/admin/enrollments/import" enctype="multipart/form-data" id="importForm">
          <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
            <input type="file" name="csv" accept=".csv,text/csv" required style="font-size: 0.85rem;">
            <button type="submit" class="btn btn-green btn-sm">Import</button>
          </div>
        </form>
      </div>

      <h3 style="margin-bottom: 12px; color: var(--green-dark);">Or Add Manually</h3>
      <form method="POST" action="/admin/enrollments/import-manual" style="max-width: 640px;">
        <div class="form-row">
          <div class="form-group">
            <label>Parent Name <span class="req">*</span></label>
            <input type="text" name="parent_name" required>
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" name="email">
          </div>
        </div>
        <div class="form-group">
          <label>Phone</label>
          <input type="tel" name="phone">
        </div>
        <div class="form-group">
          <label>Child Name(s) <span style="font-weight:normal; color:var(--text-light);">(comma-separated for multiple)</span></label>
          <input type="text" name="child_names" required>
        </div>
        <div class="form-group">
          <label>Child DOB(s) <span style="font-weight:normal; color:var(--text-light);">(comma-separated, YYYY-MM-DD)</span></label>
          <input type="text" name="child_dobs" placeholder="2021-03-15, 2023-01-10">
        </div>
        <div class="form-group">
          <label>Allergies</label>
          <input type="text" name="allergies">
        </div>
        <div class="form-group">
          <label>Notes</label>
          <textarea name="notes" rows="2"></textarea>
        </div>
        <button type="submit" class="btn btn-green btn-sm">Add Contact</button>
      </form>
    <% } %>
  </main>
</div>

<%- include('../layout_foot') %>
