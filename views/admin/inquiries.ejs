<%- include('../layout_head', { title: 'Inquiries' }) %>
<link rel="stylesheet" href="/css/admin.css">

<div class="admin-layout">
  <%- include('_sidebar', { active: 'inquiries' }) %>
  <main class="admin-main">
    <h1>Inquiries</h1>

    <% if (inquiries.length === 0) { %>
      <p style="color: var(--text-light);">No inquiries yet.</p>
    <% } else { %>
      <table class="data-table">
        <thead>
          <tr>
            <th>Status</th>
            <th>Subject</th>
            <th>From</th>
            <th>Contact</th>
            <th>Message</th>
            <th>Received</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% inquiries.forEach(i => { %>
            <tr>
              <td>
                <span class="badge badge-<%= i.status === 'new' ? 'draft' : 'sent' %>"><%= i.status %></span>
              </td>
              <td><%= i.subject %></td>
              <td><%= i.name || '—' %></td>
              <td style="font-size: 0.8rem;">
                <% if (i.email) { %><div><%= i.email %></div><% } %>
                <% if (i.phone) { %><div><%= i.phone %></div><% } %>
              </td>
              <td style="font-size: 0.85rem; max-width: 250px;"><%= i.message %></td>
              <td style="font-size: 0.8rem;"><%= i.createdAt %></td>
              <td>
                <a href="/admin/inquiries/<%= i.id %>" class="btn btn-outline btn-sm">
                  <%= i.status === 'new' ? 'Reply' : 'View' %>
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </main>
</div>

<%- include('../layout_foot') %>
