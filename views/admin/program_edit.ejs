<%- include('../layout_head', { title: 'Edit ' + program.name }) %>
<link rel="stylesheet" href="/css/admin.css">

<div class="admin-layout">
  <%- include('_sidebar', { active: 'programs' }) %>
  <main class="admin-main">
    <h1>Edit: <%= program.name %></h1>
    <p style="margin-bottom: 24px;">
      <a href="/programs/<%= program.slug || program.id %>" target="_blank" class="btn btn-outline btn-sm">Preview Page</a>
    </p>

    <!-- Hero Section -->
    <h2 style="margin-bottom: 12px;">Hero</h2>
    <form method="POST" action="/admin/programs/<%= program.id %>/hero" id="heroForm" style="margin-bottom: 24px; background: var(--sand); border-radius: var(--radius); padding: 20px;">
      <div class="form-group">
        <label>Title (defaults to program name)</label>
        <input type="text" name="hero_title" value="<%= program.heroTitle || '' %>" placeholder="<%= program.name %>"
          style="padding: 8px 12px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;">
      </div>
      <div class="form-group">
        <label>Subtitle (defaults to program description)</label>
        <input type="text" name="hero_subtitle" value="<%= program.heroSubtitle || '' %>" placeholder="<%= program.description %>"
          style="padding: 8px 12px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;">
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
        <div class="form-group">
          <label>Overlay Color <span style="font-weight:normal; color:var(--text-light);">(e.g. rgba(44,74,46,0.75))</span></label>
          <input type="text" name="hero_overlay" value="<%= program.heroOverlay || '' %>" placeholder="rgba(44,74,46,0.75)"
            style="padding: 8px 12px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;">
        </div>
        <div class="form-group">
          <label>Image Position <span style="font-weight:normal; color:var(--text-light);">(e.g. center top, 50% 30%)</span></label>
          <input type="text" name="hero_position" value="<%= program.heroPosition || '' %>" placeholder="center center"
            style="padding: 8px 12px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;">
        </div>
      </div>
      <div style="margin-bottom: 12px;">
        <% if (program.heroImage) { %>
          <img src="<%= program.heroImage %>" style="max-width: 300px; border-radius: var(--radius); border: 1px solid #ddd; margin-bottom: 8px; display: block;">
        <% } %>
        <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
          <input type="file" id="heroFile" accept="image/*" style="font-size: 0.85rem;">
          <button type="button" class="btn btn-outline btn-sm" onclick="uploadHeroImage()">Upload Image</button>
          <% if (program.heroImage) { %>
            <button type="button" class="btn btn-danger btn-sm" onclick="document.getElementById('heroUrlHidden').value=''; document.getElementById('heroForm').submit();">Remove Image</button>
          <% } %>
        </div>
        <div id="heroStatus" style="font-size: 0.85rem; color: var(--text-light); margin-top: 8px;"></div>
      </div>
      <input type="hidden" name="url" id="heroUrlHidden" value="<%= program.heroImage || '' %>">
      <button type="submit" class="btn btn-green btn-sm">Save Hero</button>
    </form>

    <!-- Registration Description -->
    <h2 style="margin-bottom: 12px;">Registration Description</h2>
    <p style="font-size: 0.85rem; color: var(--text-light); margin-bottom: 8px;">Short summary shown on the registration page when this program is selected.</p>
    <form method="POST" action="/admin/programs/<%= program.id %>/reg-description" id="regDescForm" style="margin-bottom: 32px;">
      <div id="regDescEditor" style="min-height: 120px; background: var(--white);"></div>
      <input type="hidden" name="registration_description" id="regDescHidden">
      <button type="submit" class="btn btn-green btn-sm" style="margin-top: 12px;">Save Registration Description</button>
    </form>

    <!-- Registration Form Builder -->
    <% const fc = program.formConfig; %>
    <h2 style="margin-bottom: 4px;">Registration Form Builder</h2>
    <p style="font-size: 0.85rem; color: var(--text-light); margin-bottom: 12px;">For each field on the registration form, choose whether it's shown, whether it's required, and what label to display.</p>
    <form method="POST" action="/admin/programs/<%= program.id %>/form-config" style="margin-bottom: 32px; background: var(--sand); border-radius: var(--radius); padding: 20px;">

      <!-- Page heading -->
      <h3 style="font-size: 0.95rem; margin-bottom: 8px; color: var(--green-dark);">Page heading</h3>
      <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 12px; align-items: end; margin-bottom: 16px;">
        <div class="form-group" style="margin: 0;">
          <label style="font-size: 0.8rem;">Title prefix <span style="font-weight:normal; color:var(--text-light);">(default: Registration)</span></label>
          <input type="text" name="page_title_prefix" value="<%= fc.pageTitlePrefix === 'Registration' ? '' : fc.pageTitlePrefix %>" placeholder="Registration"
            style="padding: 8px 10px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;">
        </div>
        <div class="form-group" style="margin: 0;">
          <label style="font-size: 0.8rem;">Lead text <span style="font-weight:normal; color:var(--text-light);">(optional)</span></label>
          <input type="text" name="page_lead" value="<%= fc.pageLead || '' %>" placeholder="Select a program and dates, then fill in your information below."
            style="padding: 8px 10px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;">
        </div>
      </div>
      <div style="margin-bottom: 20px;">
        <label style="display: inline-flex; align-items: center; gap: 8px; cursor: pointer; font-weight: 400;">
          <input type="checkbox" name="show_program_selector" <%= fc.programSelector.show ? 'checked' : '' %>
            style="width: auto; padding: 0; margin: 0; border: none;">
          Show program selector on registration page <span style="color: var(--text-light); font-size: 0.85rem;">(uncheck to lock visitors to this program when they arrive via its direct URL)</span>
        </label>
      </div>

      <h3 style="font-size: 0.95rem; margin-bottom: 8px; color: var(--green-dark);">Contact information</h3>
      <div class="field-table" style="display: grid; grid-template-columns: 200px 80px 80px 1fr; gap: 8px 12px; align-items: center; margin-bottom: 20px; font-size: 0.85rem;">
        <div style="font-weight: 700; color: var(--text-light);">Field</div>
        <div style="font-weight: 700; color: var(--text-light); text-align: center;">Show</div>
        <div style="font-weight: 700; color: var(--text-light); text-align: center;">Required</div>
        <div style="font-weight: 700; color: var(--text-light);">Label</div>

        <% function fieldRow(key, fieldKey, fieldLabel, fc) { %>
          <div><%= fieldLabel %></div>
          <div style="text-align: center;"><input type="checkbox" name="<%= key %>_show" <%= fc.show ? 'checked' : '' %> style="width: auto; padding: 0; margin: 0; border: none;"></div>
          <div style="text-align: center;"><input type="checkbox" name="<%= key %>_required" <%= fc.required ? 'checked' : '' %> style="width: auto; padding: 0; margin: 0; border: none;"></div>
          <div><input type="text" name="<%= key %>_label" value="<%= fc.label || '' %>" placeholder="<%= fc.label || '' %>" style="padding: 6px 10px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;"></div>
        <% } %>

        <% fieldRow('contact_name',  'contactName',  'Contact Name',  fc.contactName); %>
        <% fieldRow('contact_email', 'contactEmail', 'Contact Email', fc.contactEmail); %>
        <% fieldRow('contact_phone', 'contactPhone', 'Contact Phone', fc.contactPhone); %>
      </div>

      <h3 style="font-size: 0.95rem; margin-bottom: 8px; color: var(--green-dark);">Participant information</h3>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
        <div class="form-group" style="margin: 0;">
          <label style="font-size: 0.8rem;">Section heading <span style="font-weight:normal; color:var(--text-light);">(default: Children)</span></label>
          <input type="text" name="participants_heading" value="<%= fc.participants.sectionHeading === 'Children' ? '' : fc.participants.sectionHeading %>" placeholder="Children"
            style="padding: 8px 10px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;">
        </div>
        <div class="form-group" style="margin: 0;">
          <label style="font-size: 0.8rem;">Singular label <span style="font-weight:normal; color:var(--text-light);">(default: Child)</span></label>
          <input type="text" name="participant_singular_label" value="<%= fc.participants.singularLabel === 'Child' ? '' : fc.participants.singularLabel %>" placeholder="Child"
            style="padding: 8px 10px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;">
        </div>
      </div>
      <div style="margin-bottom: 12px;">
        <label style="display: inline-flex; align-items: center; gap: 8px; cursor: pointer; font-weight: 400; font-size: 0.85rem;">
          <input type="checkbox" name="single_participant_only" <%= fc.participants.singleOnly ? 'checked' : '' %>
            style="width: auto; padding: 0; margin: 0; border: none;">
          Single participant only <span style="color: var(--text-light);">(hides the "+ Add Another" link)</span>
        </label>
      </div>
      <div style="display: grid; grid-template-columns: 200px 80px 80px 1fr; gap: 8px 12px; align-items: center; margin-bottom: 20px; font-size: 0.85rem;">
        <div style="font-weight: 700; color: var(--text-light);">Field</div>
        <div style="font-weight: 700; color: var(--text-light); text-align: center;">Show</div>
        <div style="font-weight: 700; color: var(--text-light); text-align: center;">Required</div>
        <div style="font-weight: 700; color: var(--text-light);">Label</div>

        <!-- Participant Name: label override only if you want to override the auto "<Singular>'s Name" -->
        <div>Name</div>
        <div style="text-align: center;"><input type="checkbox" name="pname_show" <%= fc.participants.fields.name.show ? 'checked' : '' %> style="width: auto; padding: 0; margin: 0; border: none;"></div>
        <div style="text-align: center;"><input type="checkbox" name="pname_required" <%= fc.participants.fields.name.required ? 'checked' : '' %> style="width: auto; padding: 0; margin: 0; border: none;"></div>
        <div><input type="text" name="pname_label" value="<%= fc.participants.fields.name.label || '' %>" placeholder="<%= fc.participants.singularLabel %>&apos;s Name" style="padding: 6px 10px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;"></div>

        <% fieldRow('pdob',        'dob',        'Date of Birth',       fc.participants.fields.dob); %>
        <% fieldRow('phealthcare', 'healthcare', 'Healthcare Provider', fc.participants.fields.healthcare); %>
        <% fieldRow('pallergies',  'allergies',  'Allergies',           fc.participants.fields.allergies); %>
      </div>

      <h3 style="font-size: 0.95rem; margin-bottom: 8px; color: var(--green-dark);">Other</h3>
      <div style="display: grid; grid-template-columns: 200px 80px 80px 1fr; gap: 8px 12px; align-items: center; margin-bottom: 20px; font-size: 0.85rem;">
        <div style="font-weight: 700; color: var(--text-light);">Field</div>
        <div style="font-weight: 700; color: var(--text-light); text-align: center;">Show</div>
        <div style="font-weight: 700; color: var(--text-light); text-align: center;">Required</div>
        <div style="font-weight: 700; color: var(--text-light);">Label</div>

        <% fieldRow('notes', 'notes', 'Notes', fc.notes); %>

        <div>Terms checkbox <div style="font-size: 0.75rem; color: var(--text-light);">body edited at <a href="/admin/pages/waiver/edit">Site Pages → Waiver</a></div></div>
        <div style="text-align: center;"><input type="checkbox" name="terms_show" <%= fc.terms.show ? 'checked' : '' %> style="width: auto; padding: 0; margin: 0; border: none;"></div>
        <div style="text-align: center;"><input type="checkbox" name="terms_required" <%= fc.terms.required ? 'checked' : '' %> style="width: auto; padding: 0; margin: 0; border: none;"></div>
        <div style="color: var(--text-light); font-size: 0.8rem;">(no label override)</div>
      </div>

      <button type="submit" class="btn btn-green btn-sm">Save Registration Form</button>
    </form>

    <!-- Custom Registration Questions -->
    <h2 style="margin-bottom: 4px;">Additional Registration Questions</h2>
    <p style="font-size: 0.85rem; color: var(--text-light); margin-bottom: 12px;">Extra questions shown on the registration page for this program. Order matters; add as many as you need.</p>
    <form method="POST" action="/admin/programs/<%= program.id %>/custom-questions" id="customQuestionsForm" style="margin-bottom: 32px; background: var(--sand); border-radius: var(--radius); padding: 20px;">
      <div id="questionsList">
        <% (program.customQuestions || []).forEach((q, i) => { %>
          <div class="question-row" data-idx="<%= i %>" style="background: var(--white); border-radius: var(--radius); padding: 14px; margin-bottom: 10px; border: 1px solid #e0ddd5;">
            <div style="display: grid; grid-template-columns: 2fr 2fr 110px 110px 70px; gap: 10px; align-items: end;">
              <div class="form-group" style="margin: 0;">
                <label style="font-size: 0.8rem;">Question <span class="req">*</span></label>
                <input type="text" name="question_label" value="<%= q.label %>" required
                  style="padding: 8px 10px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;">
              </div>
              <div class="form-group" style="margin: 0;">
                <label style="font-size: 0.8rem;">Help text <span style="font-weight:normal; color:var(--text-light);">(optional)</span></label>
                <input type="text" name="question_help" value="<%= q.helpText || '' %>"
                  style="padding: 8px 10px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;">
              </div>
              <div class="form-group" style="margin: 0;">
                <label style="font-size: 0.8rem;">Type</label>
                <select name="question_type" style="padding: 8px 10px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;">
                  <option value="text" <%= q.type !== 'textarea' ? 'selected' : '' %>>Short text</option>
                  <option value="textarea" <%= q.type === 'textarea' ? 'selected' : '' %>>Long text</option>
                </select>
              </div>
              <div style="margin: 0;">
                <label style="display: inline-flex; align-items: center; gap: 6px; font-size: 0.8rem; cursor: pointer; margin-top: 18px;">
                  <input type="checkbox" name="question_required_idx" value="<%= i %>" <%= q.required ? 'checked' : '' %>
                    style="width: auto; padding: 0; margin: 0; border: none;">
                  Required
                </label>
              </div>
              <div style="margin-top: 18px;">
                <button type="button" class="btn btn-danger btn-sm remove-question">Remove</button>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      <a href="#" id="addQuestionBtn" style="display: inline-block; margin-bottom: 12px; color: var(--green-dark); font-weight: 600;">+ Add Question</a>
      <div>
        <button type="submit" class="btn btn-green btn-sm">Save Questions</button>
      </div>
    </form>
    <script>
    (function() {
      const list = document.getElementById('questionsList');
      const addBtn = document.getElementById('addQuestionBtn');
      function nextIdx() {
        return list.querySelectorAll('.question-row').length;
      }
      function buildRow(idx) {
        const div = document.createElement('div');
        div.className = 'question-row';
        div.dataset.idx = idx;
        div.style.cssText = 'background: var(--white); border-radius: var(--radius); padding: 14px; margin-bottom: 10px; border: 1px solid #e0ddd5;';
        div.innerHTML = `
          <div style="display: grid; grid-template-columns: 2fr 2fr 110px 110px 70px; gap: 10px; align-items: end;">
            <div class="form-group" style="margin: 0;">
              <label style="font-size: 0.8rem;">Question <span class="req">*</span></label>
              <input type="text" name="question_label" required style="padding: 8px 10px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;">
            </div>
            <div class="form-group" style="margin: 0;">
              <label style="font-size: 0.8rem;">Help text <span style="font-weight:normal; color:var(--text-light);">(optional)</span></label>
              <input type="text" name="question_help" style="padding: 8px 10px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;">
            </div>
            <div class="form-group" style="margin: 0;">
              <label style="font-size: 0.8rem;">Type</label>
              <select name="question_type" style="padding: 8px 10px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;">
                <option value="text" selected>Short text</option>
                <option value="textarea">Long text</option>
              </select>
            </div>
            <div style="margin: 0;">
              <label style="display: inline-flex; align-items: center; gap: 6px; font-size: 0.8rem; cursor: pointer; margin-top: 18px;">
                <input type="checkbox" name="question_required_idx" value="${idx}" style="width: auto; padding: 0; margin: 0; border: none;">
                Required
              </label>
            </div>
            <div style="margin-top: 18px;">
              <button type="button" class="btn btn-danger btn-sm remove-question">Remove</button>
            </div>
          </div>
        `;
        return div;
      }
      addBtn.addEventListener('click', function(e) {
        e.preventDefault();
        list.appendChild(buildRow(nextIdx()));
      });
      list.addEventListener('click', function(e) {
        if (e.target.classList.contains('remove-question')) {
          e.target.closest('.question-row').remove();
          // Re-index required-checkbox values so they still align with field positions on POST.
          list.querySelectorAll('.question-row').forEach((row, i) => {
            row.dataset.idx = i;
            const cb = row.querySelector('input[name="question_required_idx"]');
            if (cb) cb.value = i;
          });
        }
      });
    })();
    </script>

    <!-- Long Description -->
    <h2 style="margin-bottom: 12px;">Description</h2>
    <link href="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css" rel="stylesheet">
    <form method="POST" action="/admin/programs/<%= program.id %>/content" id="descForm" style="margin-bottom: 32px;">
      <div id="editor" style="min-height: 200px; background: var(--white); border-radius: 0 0 var(--radius) var(--radius);"></div>
      <input type="hidden" name="long_description" id="descHidden">
      <button type="submit" class="btn btn-green btn-sm" style="margin-top: 12px;">Save Description</button>
    </form>
    <script src="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js"></script>
    <script src="/js/admin-quill.js"></script>
    <script>
    // Pre-process: if existing content is plain text (no HTML tags), convert newlines to paragraphs
    let existingContent = <%- JSON.stringify(program.longDescription || '') %>;
    if (existingContent && !existingContent.includes('<')) {
      existingContent = existingContent.split(/\n+/).filter(Boolean).map(p => '<p>' + p + '</p>').join('');
    }
    document.getElementById('editor').innerHTML = existingContent;

    const quill = createAdminQuill('#editor', {
      placeholder: 'Detailed program description...',
      allowHtmlToggle: true,
    });

    document.getElementById('descForm').addEventListener('submit', function() {
      document.getElementById('descHidden').value = quill.getCleanHtml();
    });

    // Registration description editor
    let regDescContent = <%- JSON.stringify(program.registrationDescription || '') %>;
    if (regDescContent && !regDescContent.includes('<')) {
      regDescContent = regDescContent.split(/\n+/).filter(Boolean).map(p => '<p>' + p + '</p>').join('');
    }
    document.getElementById('regDescEditor').innerHTML = regDescContent;

    const regDescQuill = createAdminQuill('#regDescEditor', {
      placeholder: 'Short description shown during registration...',
    });

    document.getElementById('regDescForm').addEventListener('submit', function() {
      document.getElementById('regDescHidden').value = regDescQuill.getCleanHtml();
    });
    </script>

    <!-- Media Gallery -->
    <h2 style="margin-bottom: 12px;">Media</h2>

    <% const media = program.media || []; %>
    <% if (media.length > 0) { %>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px;">
        <% media.forEach((m, idx) => { %>
          <div style="background: var(--white); border-radius: var(--radius); border: 1px solid #ddd; overflow: hidden;">
            <% if (m.type === 'image') { %>
              <img src="<%= m.url %>" style="width: 100%; height: 150px; object-fit: cover;">
            <% } else { %>
              <video src="<%= m.url %>" style="width: 100%; height: 150px; object-fit: cover;" preload="metadata"></video>
            <% } %>
            <div style="padding: 8px;">
              <div style="font-size: 0.8rem; color: var(--text-light); margin-bottom: 6px;"><%= m.type %><%= m.caption ? ': ' + m.caption : '' %></div>
              <form method="POST" action="/admin/programs/<%= program.id %>/media/remove">
                <input type="hidden" name="index" value="<%= idx %>">
                <input type="hidden" name="key" value="<%= m.key || '' %>">
                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Remove this media?')">Remove</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <div style="background: var(--sand); border-radius: var(--radius); padding: 20px; margin-bottom: 24px;">
      <h3 style="margin-bottom: 12px; font-size: 1rem; color: var(--green-dark);">Add Media</h3>
      <div class="form-group">
        <label>File (image or video)</label>
        <input type="file" id="mediaFile" accept="image/*,video/*" style="font-size: 0.85rem;">
      </div>
      <div class="form-group">
        <label>Caption (optional)</label>
        <input type="text" id="mediaCaption" style="padding: 8px 12px; border: 1px solid #ccc; border-radius: var(--radius); width: 100%;">
      </div>
      <button type="button" class="btn btn-green btn-sm" onclick="uploadMedia()">Upload</button>
      <div id="mediaStatus" style="font-size: 0.85rem; color: var(--text-light); margin-top: 8px;"></div>
    </div>

    <a href="/admin/programs" class="btn btn-outline">Back to Programs</a>
  </main>
</div>

<script>
async function getPresignedUrl(filename, contentType) {
  const res = await fetch('/admin/programs/<%= program.id %>/upload-url', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ filename, contentType }),
  });
  return res.json();
}

async function uploadToS3(file, presigned) {
  await fetch(presigned.uploadUrl, {
    method: 'PUT',
    headers: { 'Content-Type': file.type },
    body: file,
  });
  return presigned;
}

async function uploadHeroImage() {
  const file = document.getElementById('heroFile').files[0];
  const status = document.getElementById('heroStatus');
  if (!file) { status.textContent = 'Select a file first.'; return; }
  if (!file.type.startsWith('image/')) { status.textContent = 'Must be an image.'; return; }

  status.textContent = 'Uploading...';
  try {
    const presigned = await getPresignedUrl(file.name, file.type);
    await uploadToS3(file, presigned);
    // Set the hidden URL field and submit the hero form
    document.getElementById('heroUrlHidden').value = presigned.publicUrl;
    document.getElementById('heroForm').submit();
  } catch (err) {
    status.textContent = 'Upload failed: ' + err.message;
  }
}

async function uploadMedia() {
  const file = document.getElementById('mediaFile').files[0];
  const caption = document.getElementById('mediaCaption').value.trim();
  const status = document.getElementById('mediaStatus');
  if (!file) { status.textContent = 'Select a file first.'; return; }

  const type = file.type.startsWith('video/') ? 'video' : 'image';
  status.textContent = 'Uploading...';
  try {
    const presigned = await getPresignedUrl(file.name, file.type);
    await uploadToS3(file, presigned);

    // Save the media entry
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/admin/programs/<%= program.id %>/media';
    [['type', type], ['url', presigned.publicUrl], ['key', presigned.key], ['caption', caption]].forEach(([k, v]) => {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = k;
      input.value = v;
      form.appendChild(input);
    });
    document.body.appendChild(form);
    form.submit();
  } catch (err) {
    status.textContent = 'Upload failed: ' + err.message;
  }
}
</script>

